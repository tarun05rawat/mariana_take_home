{
  "name": "mariana-minerals-takehome",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:client": "vite",
    "dev:server": "node --import tsx server/index.ts",
    "build": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "import-data": "./.venv/bin/python scripts/import_data.py",
    "check": "tsc --noEmit",
    "test:python": "./.venv/bin/python -m unittest scripts/test_import_data.py scripts/test_database_smoke.py",
    "test:ts": "vitest run",
    "test": "./.venv/bin/python -m unittest scripts/test_import_data.py scripts/test_database_smoke.py && vitest run"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.28.0",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.15",
    "@types/node": "^22.10.2",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "happy-dom": "^17.6.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^3.2.4"
  }
}
